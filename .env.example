# Coolify / Docker Compose ortam değişkenleri

# Aynı origin'den yayın yapılacaksa boş bırakılabilir.
# Farklı domain/subdomain kullanılıyorsa virgülle ayırarak yazın:
# CORS_ALLOWED_ORIGINS=https://olaylar.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Oturum önbelleği (kalıcı volüm olarak mount edilir)
SESSION_CACHE_DIR=/app/backend/session_cache

# Aynı anda tutulacak maksimum oturum sayısı
MAX_SESSIONS=20

# Oturumun diskte ve bellekte ne kadar kalacağı (saniye)
SESSION_TTL_SECONDS=1800
